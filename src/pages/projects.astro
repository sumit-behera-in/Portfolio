---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import ProjectTabs from '../components/ProjectTabs.jsx';
import { loadProfileData, loadReposData, getMockProfileData, getMockReposData, getLastUpdated, loadSocialLinks } from '../utils/getData';

let profile = loadProfileData() || getMockProfileData();
let reposData = loadReposData();
const lastUpdated = getLastUpdated();
const socialLinks = loadSocialLinks();

if (!reposData || reposData.owned.length === 0) {
  reposData = getMockReposData();
}

const allProjects = (reposData.owned || [])
  .slice()
  .sort((a, b) => new Date(b.updatedAt).getTime() - new Date(a.updatedAt).getTime());
const featuredProjects = allProjects.filter((project) => project.featured);
---

<Layout title={`Projects - ${profile.name}`} description="All projects and repositories">
  <!-- Header -->
  <section class="pt-32 pb-16 bg-gradient-to-br from-blue-50 to-indigo-100 dark:from-slate-900 dark:to-slate-800">
    <div class="container-max">
      <h1 class="text-5xl md:text-6xl font-bold mb-4">
        <span class="gradient-text">All Projects</span>
      </h1>
      <p class="text-xl text-slate-600 dark:text-slate-400">
        Complete collection of my work and contributions
      </p>
    </div>
  </section>

  <ProjectTabs client:load allProjects={allProjects} featuredProjects={featuredProjects} />

  <Footer profile={profile} lastUpdated={lastUpdated} socialLinks={socialLinks} />
</Layout>
