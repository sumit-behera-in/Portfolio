---
import { Star, GitFork, ExternalLink } from 'lucide-react';
import { formatProjectName } from '../utils/getData';

const { project } = Astro.props;

function formatMonth(value) {
  if (!value) return null;
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return null;
  return date.toLocaleString('en-US', { month: 'short', year: 'numeric' });
}

const createdLabel = formatMonth(project.createdAt);
const completedLabel = formatMonth(project.updatedAt);
const release = project.latestRelease;
const releaseLabel = release ? release.tagName || release.name || 'Release' : null;
---

<article class="card block p-6 hover:shadow-xl transition-all group flex flex-col">
  {project.image && (
    <a
      href={project.url}
      target="_blank"
      rel="noopener noreferrer"
      class="mb-4 rounded-xl overflow-hidden h-48 bg-slate-200 dark:bg-slate-700 block overflow-hidden"
    >
      <img
        src={project.image}
        alt={project.name}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform"
        loading="lazy"
      />
    </a>
  )}

  <div class="flex flex-wrap gap-2 mb-3">
    <span class="px-3 py-1 bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-200 rounded-full text-sm font-medium">
      {project.language || 'Unknown'}
    </span>
    {project.featured && (
      <span class="px-3 py-1 bg-yellow-100 dark:bg-yellow-900 text-yellow-700 dark:text-yellow-200 rounded-full text-sm font-medium">
        ⭐ Featured
      </span>
    )}
    {project.isOwned && (
      <span class="px-3 py-1 bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-200 rounded-full text-sm font-medium">
        👤 Owned
      </span>
    )}
  </div>

  <h3 class="text-xl font-bold mb-3 text-slate-900 dark:text-white transition-colors">
    <a
      href={project.url}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block group-hover:text-blue-500 transition-colors"
    >
      {formatProjectName(project.name)}
    </a>
  </h3>

  <p class="text-sm text-slate-600 dark:text-slate-400 mb-4 flex-grow line-clamp-2">
    {project.description}
  </p>

  {project.topics && project.topics.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-4">
      {project.topics.slice(0, 4).map((topic) => (
        <span class="text-xs px-2 py-1 bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-full">
          #{topic}
        </span>
      ))}
    </div>
  )}

  <div class="space-y-2 text-sm text-slate-600 dark:text-slate-400 mb-4">
    {createdLabel && <div>Created {createdLabel}</div>}
    {completedLabel && <div>Completed {completedLabel}</div>}
    {release && (
      <a
        href={release.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-blue-600 dark:text-blue-300 hover:underline"
      >
        <ExternalLink class="w-4 h-4" />
        <span>Latest release {releaseLabel}</span>
        {release.publishedAt && <span class="text-slate-500 dark:text-slate-400">• {formatMonth(release.publishedAt)}</span>}
      </a>
    )}
  </div>

  <div class="flex items-center justify-between pt-4 border-t border-slate-200 dark:border-slate-700 mt-auto text-slate-600 dark:text-slate-400">
    <div class="flex gap-4 text-sm">
      <div class="flex items-center gap-1">
        <Star class="w-4 h-4" />
        <span>{project.stars}</span>
      </div>
      <div class="flex items-center gap-1">
        <GitFork class="w-4 h-4" />
        <span>{project.forks || 0}</span>
      </div>
    </div>

    <div class="text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">
      Updated {completedLabel || '—'}
    </div>
  </div>
</a>
