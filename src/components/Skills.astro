---
interface Props {
  skillsByCategory: Record<string, { name: string; icon: string }[]>;
}

const { skillsByCategory } = Astro.props;
const categoryEntries = Object.entries(skillsByCategory || {});
const totalSkills = categoryEntries.reduce((count, [, items]) => count + items.length, 0);
---

<section class="py-20 bg-slate-50 dark:bg-slate-800">
  <div class="container-max">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        <span class="gradient-text">Skills & Technologies</span>
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-400">
        A dynamic collection of the tools, languages, and frameworks I use most.
      </p>
    </div>

    <!-- Skills Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
      {categoryEntries.map(([category, items]) => (
        <div class="card p-8">
          <h3 class="text-xl font-bold mb-6 text-blue-600 dark:text-blue-400 capitalize">
            {category.replace(/([A-Z])/g, ' $1').trim()}
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
            {items.map((skill) => (
              <div class="min-h-[120px] flex flex-col items-center justify-center gap-3 rounded-3xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-950 p-4 text-center shadow-sm">
                <div class="w-16 h-16 rounded-full bg-slate-100 dark:bg-slate-900 flex items-center justify-center overflow-hidden">
                  {skill.icon ? (
                    <img
                      src={skill.icon}
                      alt={skill.name}
                      class="w-full h-full object-contain"
                      loading="lazy"
                    />
                  ) : (
                    <span class="text-xl font-semibold text-slate-600 dark:text-slate-300">
                      {skill.name.charAt(0)}
                    </span>
                  )}
                </div>
                <div class="text-sm font-medium text-slate-900 dark:text-white">
                  {skill.name}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Stats -->
    <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="card p-8 text-center">
        <div class="text-4xl font-bold text-blue-500 mb-2">
          {totalSkills}
        </div>
        <p class="text-slate-600 dark:text-slate-400">Skills Loaded</p>
      </div>
      <div class="card p-8 text-center">
        <div class="text-4xl font-bold text-blue-500 mb-2">
          {categoryEntries.length}
        </div>
        <p class="text-slate-600 dark:text-slate-400">Skill Categories</p>
      </div>
      <div class="card p-8 text-center">
        <div class="text-4xl font-bold text-blue-500 mb-2">
          ∞
        </div>
        <p class="text-slate-600 dark:text-slate-400">Always Learning</p>
      </div>
    </div>
  </div>
</section>
