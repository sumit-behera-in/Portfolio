---
import { Star, GitFork, ExternalLink, Play } from 'lucide-react';

interface Project {
  name: string;
  description: string;
  url: string;
  stars: number;
  language: string;
  topics: string[];
  featured: boolean;
  demo?: string;
  live?: string;
  image?: string;
}

interface Props {
  projects: Project[];
  title?: string;
}

const { projects, title = 'Featured Projects' } = Astro.props;
const featuredProjects = projects.filter(p => p.featured).slice(0, 6);
---

<section class="py-20 bg-white dark:bg-slate-900">
  <div class="container-max">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        <span class="gradient-text">{title}</span>
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-400">
        Showcase of my best work and contributions
      </p>
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {featuredProjects.map((project) => (
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class="card p-6 hover:shadow-xl transition-all group cursor-pointer"
        >
          <!-- Project Image -->
          {project.image && (
            <div class="mb-4 rounded-lg overflow-hidden h-48 bg-slate-200 dark:bg-slate-700">
              <img
                src={project.image}
                alt={project.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                loading="lazy"
              />
            </div>
          )}

          <!-- Language Badge -->
          <div class="flex gap-2 mb-3">
            <span class="px-3 py-1 bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-200 rounded-full text-sm font-medium">
              {project.language}
            </span>
            {project.featured && (
              <span class="px-3 py-1 bg-yellow-100 dark:bg-yellow-900 text-yellow-700 dark:text-yellow-200 rounded-full text-sm font-medium">
                ⭐ Featured
              </span>
            )}
          </div>

          <!-- Title -->
          <h3 class="text-xl font-bold mb-2 text-slate-900 dark:text-white group-hover:text-blue-500 transition-colors">
            {project.name}
          </h3>

          <!-- Description -->
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-4 line-clamp-2">
            {project.description}
          </p>

          <!-- Topics -->
          {project.topics && project.topics.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-4">
              {project.topics.slice(0, 3).map((topic) => (
                <span class="text-xs px-2 py-1 bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-300 rounded">
                  #{topic}
                </span>
              ))}
            </div>
          )}

          <!-- Stats & Links -->
          <div class="flex items-center justify-between pt-4 border-t border-slate-200 dark:border-slate-700">
            <div class="flex gap-4 text-sm text-slate-600 dark:text-slate-400">
              <div class="flex items-center gap-1">
                <Star class="w-4 h-4" />
                <span>{project.stars}</span>
              </div>
              <div class="flex items-center gap-1">
                <GitFork class="w-4 h-4" />
                <span>Fork</span>
              </div>
            </div>

            <div class="flex gap-2">
              {project.demo && (
                <a
                  href={project.demo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="p-2 hover:bg-blue-100 dark:hover:bg-blue-900 rounded-lg transition-colors"
                  title="Demo"
                >
                  <Play class="w-4 h-4 text-blue-500" />
                </a>
              )}
              {project.live && (
                <a
                  href={project.live}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="p-2 hover:bg-blue-100 dark:hover:bg-blue-900 rounded-lg transition-colors"
                  title="Live"
                >
                  <ExternalLink class="w-4 h-4 text-blue-500" />
                </a>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- View More Button -->
    <div class="text-center mt-12">
      <a href="/projects" class="btn-primary">
        View All Projects →
      </a>
    </div>
  </div>
</section>
